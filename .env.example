# PromptForge Verse — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git. It is already gitignored.

# ─── Firebase (Client SDK) ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Razorpay ─────────────────────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX   # public key, safe in frontend
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX        # server-side duplicate
RAZORPAY_KEY_SECRET=your_razorpay_key_secret     # KEEP SECRET, backend only

# ─── Firebase Admin SDK (backend / serverless only) ───────────────────────────
# These are NEVER exposed to the frontend.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── AI Provider Keys (backend only) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key
DEEPSEEK_API_KEY=your_deepseek_key
HF_API_KEY=your_huggingface_key

# ─── Monitoring (optional — degrades gracefully if not set) ──────────────────
VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxxxx    # frontend Sentry DSN
SENTRY_DSN=https://xxxx@sentry.io/xxxxxx          # backend Sentry DSN (same project)
